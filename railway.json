{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "calories_burn_prediction/Dockerfile",
    "dockerfileContext": "."
  },
  "deploy": {
    "startCommand": "cd calories_burn_prediction && streamlit run app.py --server.port $PORT --server.address 0.0.0.0",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE"
  }
}
